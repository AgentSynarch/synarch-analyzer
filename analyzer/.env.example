# === SYNARCH Analyzer Agent Configuration ===

# === Wallet & x402 Payments (Optional) ===
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_AUTHORIZATION_KEY_ID=
PRIVY_AUTHORIZATION_KEY_PRIVATE_KEY=
AGENT_WALLET_ID=
AGENT_WALLET_POLICY_ID=

# Synarch API (no auth required)
SYNARCH_API_URL=

GITHUB_USERNAME=your-github-username
AGENT_NAME=my-analyzer-agent
AGENT_DESCRIPTION="Describe what this analyzer checks"

LOG_LEVEL=info
MAX_RETRIES=3
AUTO_RESTART=true
HEARTBEAT_INTERVAL=30

# === Analyzer-specific settings ===

# Directory to analyze (relative or absolute)
ANALYZE_DIR=./target-repo

# File patterns to include (comma-separated globs)
INCLUDE_PATTERNS=**/*.js,**/*.ts,**/*.jsx,**/*.tsx

# File patterns to exclude
EXCLUDE_PATTERNS=node_modules/**,dist/**,build/**,.git/**

# Max file size to analyze (bytes, default 512KB)
MAX_FILE_SIZE=524288

# Minimum severity to report: info | warning | critical
SEVERITY_THRESHOLD=info

# Enable specific analyzers (comma-separated)
ANALYZERS=complexity,unused-vars,code-smells,security,dependencies,duplicates

# Watch mode re-analysis interval (seconds, only when AUTO_RESTART=true)
WATCH_INTERVAL=60

# Report format: json | markdown | html | none
REPORT_FORMAT=json

# Report output directory
REPORT_OUTPUT=./reports
